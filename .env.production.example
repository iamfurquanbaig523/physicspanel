APP_NAME="Physics Fundamentals Panel"
APP_ENV="production"
APP_KEY=""
APP_DEBUG="false"
APP_URL="https://panel.physicsfundamental.org"
APP_VERSION="2.0.0"
DEMO_MODE="false"

LOG_CHANNEL="stack"
LOG_DEPRECATIONS_CHANNEL="null"
LOG_LEVEL="error"

DB_CONNECTION="mysql"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="your_database_name"
DB_USERNAME="your_database_user"
DB_PASSWORD="your_database_password"

BROADCAST_DRIVER="log"
CACHE_DRIVER="file"
FILESYSTEM_DISK="public"
QUEUE_CONNECTION="sync"
SESSION_DRIVER="file"
SESSION_LIFETIME="120"
SESSION_DOMAIN=".physicsfundamental.org"
SESSION_SECURE_COOKIE="true"
CACHE_EXPIRE="-1"

CORS_ALLOWED_ORIGINS="https://physicsfundamental.org,https://www.physicsfundamental.org"
SANCTUM_STATEFUL_DOMAINS="physicsfundamental.org,www.physicsfundamental.org,panel.physicsfundamental.org"

FRONTEND_REVALIDATE_URL="https://physicsfundamental.org/api/revalidate"
