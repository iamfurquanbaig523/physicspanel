                "url": {
                    "raw": "http://127.0.0.1:8000/api/site/settings",
                    "protocol": "http",
                    "host": [
                        "127",
                        "0",
                        "0",
                        "1"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "site",
                        "settings"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "pm.test(\"Response has data object\", function () {",
                            "    var jsonData = pm.response.json();",
                            "    pm.expect(jsonData.error).to.eql(false);",
                            "    pm.expect(jsonData.data).to.be.an('object');",
                            "    pm.expect(jsonData.data).to.not.have.property('home_main_article_markdown');",
                            "});"
                        ]
                    }
                }
            ]
        },
