        {
            "name": "GET Single Blog",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://127.0.0.1:8000/api/site/blogs/{{blog_slug}}",
                    "protocol": "http",
                    "host": [
                        "127",
                        "0",
                        "0",
                        "1"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "site",
                        "blogs",
                        "{{blog_slug}}"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var slug = pm.collectionVariables.get('blog_slug');",
                            "if (slug) {",
                            "    pm.test(\"Status code is 200\", function () {",
                            "        pm.response.to.have.status(200);",
                            "    });",
                            "    pm.test(\"Response has data object\", function () {",
                            "        var jsonData = pm.response.json();",
                            "        pm.expect(jsonData.error).to.eql(false);",
                            "        pm.expect(jsonData.data).to.be.an('object');",
                            "        var links = jsonData.data.shareLinks || {};",
                            "        var firstLink = Object.keys(links).map(function (key) { return links[key]; }).find(function (link) { return link && link.shortUrl; });",
                            "        if (firstLink) {",
                            "            pm.collectionVariables.set('share_code', firstLink.shortUrl.split('/').pop());",
                            "        }",
                            "    });",
                            "} else {",
                            "    console.log('Skipping because no blog_slug was found');",
                            "}"
                        ]
                    }
                }
            ]
        },
